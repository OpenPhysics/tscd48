{
  "name": "tscd48",
  "version": "2.0.0",
  "description": "TypeScript interface for the CD48 Coincidence Counter using Web Serial API",
  "type": "module",
  "main": "./dist/cd48.umd.js",
  "module": "./dist/cd48.esm.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=22.22.1",
    "npm": ">=10.0.0"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cd48.esm.js",
      "require": "./dist/cd48.umd.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE",
    "TROUBLESHOOTING.md"
  ],
  "scripts": {
    "start": "npx serve .",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build:unminified && npm run build:minified && npm run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "build:unminified": "vite build --config vite.config.build.ts",
    "build:minified": "vite build --config vite.config.min.ts",
    "test": "vitest --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "test:coverage": "vitest --coverage --config vitest.config.ts",
    "test:integration": "vitest --run tests/integration --config vitest.config.ts",
    "test:bench": "vitest bench --run --config vitest.config.ts",
    "test:bench:watch": "vitest bench --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:examples": "playwright test tests/e2e/examples.spec.ts",
    "test:e2e:visual": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:e2e:errors": "playwright test tests/e2e/error-scenarios.spec.ts",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report tests/e2e-report",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "lint": "biome lint src tests",
    "lint:fix": "biome lint --write src tests",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "docs": "typedoc",
    "docs:serve": "npm run docs && npx serve docs",
    "prepublishOnly": "npm run build && npm run format:check && npm run test",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "commit": "cz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenPhysics/tscd48.git"
  },
  "keywords": [
    "cd48",
    "coincidence",
    "counter",
    "physics",
    "web-serial",
    "serial",
    "instrumentation",
    "red-dog-physics",
    "radiation",
    "detector",
    "geiger",
    "scintillator",
    "calibration",
    "statistical-analysis",
    "histogram",
    "time-series",
    "data-acquisition",
    "lab-equipment",
    "typescript"
  ],
  "author": "OpenPhysics Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/OpenPhysics/tscd48/issues"
  },
  "homepage": "https://github.com/OpenPhysics/tscd48#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "serve": "^14.2.6",
    "terser": "^5.48.0",
    "typedoc": "^0.28.20",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "lodash": "^4.18.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
