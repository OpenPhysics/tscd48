#!/bin/sh

echo "🚀 Running pre-push checks..."
echo ""

# Run format and lint check
echo "🔍 Running Biome check..."
if ! npm run format:check; then
  echo ""
  echo "❌ Biome check failed!"
  echo "   Run 'npm run lint:fix' or 'biome check --write .' to fix issues."
  exit 1
fi
echo "✅ Biome check passed"
echo ""

# Run TypeScript type checking
echo "📘 Running TypeScript type check..."
if ! npm run typecheck; then
  echo ""
  echo "❌ TypeScript type check failed!"
  echo "   Fix the type errors before pushing."
  exit 1
fi
echo "✅ TypeScript check passed"
echo ""

# Run tests
echo "🧪 Running tests..."
if ! npm test -- --run --reporter=verbose; then
  echo ""
  echo "❌ Tests failed!"
  echo "   Fix the failing tests before pushing."
  exit 1
fi
echo "✅ Tests passed"
echo ""

echo "✅ All pre-push checks passed! Pushing..."
